<!--index.wxml-->
<navigation-bar title="快递查询" back="{{false}}" color="black" background="#FFF"></navigation-bar>
<scroll-view class="scrollarea" scroll-y type="list">
  <view class="container">
    <view class="input-section">
      <view class="input-wrapper">
        <input class="tracking-input" placeholder="请输入快递单号" bindinput="onInput" value="{{trackingNumber}}" />
        <view class="clear-btn" wx:if="{{trackingNumber}}" bindtap="onClear">✕</view>
      </view>
      <button class="query-btn" bindtap="onQuery" disabled="{{isLoading}}">
        <text wx:if="{{isLoading}}">查询中...</text>
        <text wx:else>查询</text>
      </button>
    </view>
    
    <view class="result-section" wx:if="{{showResult}}">
      <view class="company-info">
        <text class="label">快递公司：</text>
        <text class="value">{{companyName}}</text>
      </view>
      
      <view class="loading-section" wx:if="{{isLoading}}">
        <text class="loading-text">正在查询物流信息...</text>
      </view>
      
      <view class="tracking-list" wx:if="{{trackingList.length > 0}}">
        <view class="tracking-title">物流轨迹：</view>
        <view class="tracking-item" wx:for="{{trackingList}}" wx:key="index">
          <view class="tracking-time">{{item.time}}</view>
          <view class="tracking-context">{{item.context}}</view>
        </view>
      </view>
      
      <view class="tracking-info" wx:if="{{trackingInfo && !isLoading}}">
        <text class="label">最新状态：</text>
        <text class="value">{{trackingInfo}}</text>
      </view>
    </view>
    
    <view class="error-section" wx:if="{{showError}}">
      <text class="error-message">{{errorMessage}}</text>
    </view>
    
    <view class="tips-section">
      <view class="tips-title">支持快递公司：</view>
      <view class="tips-content">顺丰、中通、圆通、韵达、申通、百世、极兔、邮政、EMS、京东</view>
    </view>
  </view>
</scroll-view>