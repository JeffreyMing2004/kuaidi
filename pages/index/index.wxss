/**index.wxss**/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.scrollarea {
  flex: 1;
  overflow-y: hidden;
}

.container {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.input-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  background-color: white;
  padding: 30rpx;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.tracking-input {
  height: 80rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}

.query-btn {
  background-color: #07c160;
  color: white;
  border: none;
  border-radius: 8rpx;
  height: 80rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.query-btn::after {
  border: none;
}

.result-section {
  background-color: white;
  padding: 30rpx;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.company-info,
.tracking-info {
  display: flex;
  margin-bottom: 20rpx;
}

.company-info:last-child,
.tracking-info:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 28rpx;
  color: #666;
  min-width: 150rpx;
}

.value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.error-section {
  background-color: #fff3f3;
  padding: 30rpx;
  border-radius: 10rpx;
  border: 1rpx solid #ffcccc;
}

.error-message {
  font-size: 28rpx;
  color: #cc0000;
}