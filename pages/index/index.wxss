/**index.wxss**/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.scrollarea {
  flex: 1;
  overflow-y: hidden;
}

.container {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.input-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  background-color: white;
  padding: 30rpx;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.tracking-input {
  height: 80rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}

.query-btn {
  background-color: #07c160;
  color: white;
  border: none;
  border-radius: 8rpx;
  height: 80rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.query-btn::after {
  border: none;
}

.result-section {
  background-color: white;
  padding: 30rpx;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.company-info,
.tracking-info {
  display: flex;
  margin-bottom: 20rpx;
}

.company-info:last-child,
.tracking-info:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 28rpx;
  color: #666;
  min-width: 150rpx;
}

.value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.loading-section {
  display: flex;
  justify-content: center;
  padding: 20rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.tracking-list {
  margin-top: 20rpx;
  border-top: 1rpx solid #eee;
  padding-top: 20rpx;
}

.tracking-title {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.tracking-item {
  display: flex;
  flex-direction: column;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.tracking-item:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.tracking-time {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.tracking-context {
  font-size: 26rpx;
  color: #333;
  line-height: 1.5;
}

.error-section {
  background-color: #fff3f3;
  padding: 30rpx;
  border-radius: 10rpx;
  border: 1rpx solid #ffcccc;
}

.error-message {
  font-size: 28rpx;
  color: #cc0000;
}

.input-wrapper {
  position: relative;
  display: flex;
  align-items: center;
}

.tracking-input {
  flex: 1;
  padding-right: 60rpx;
}

.clear-btn {
  position: absolute;
  right: 20rpx;
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #ccc;
  color: white;
  border-radius: 50%;
  font-size: 24rpx;
}

.query-btn[disabled] {
  background-color: #a0d9b1;
  color: rgba(255, 255, 255, 0.7);
}

.tips-section {
  background-color: white;
  padding: 30rpx;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.tips-title {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.tips-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

.manual-select {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #ffcccc;
}

.select-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.picker-value {
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 20rpx;
  background-color: #fff;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
}